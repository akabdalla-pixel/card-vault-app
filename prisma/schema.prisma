// Add these fields to your Card model in prisma/schema.prisma

// Find your Card model and add these 3 fields:
//
// model Card {
//   id        String   @id @default(cuid())
//   ...existing fields...
//   sold      Boolean  @default(false)
//   soldPrice Float?
//   soldDate  String?
//   ...
// }
//
// Then run: npx prisma migrate dev --name add_sold_fields
// Or for production: npx prisma migrate deploy

// FULL SCHEMA FOR REFERENCE:
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  cards     Card[]
  wishes    Wish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id        String   @id @default(cuid())
  sport     String?
  year      String?
  player    String
  name      String?
  brand     String?
  num       String?
  cond      String?
  grade     String?
  qty       Int      @default(1)
  date      String?
  buy       Float    @default(0)
  val       Float    @default(0)
  notes     String?
  sold      Boolean  @default(false)
  soldPrice Float?
  soldDate  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wish {
  id        String   @id @default(cuid())
  pri       String   @default("medium")
  sport     String?
  player    String
  name      String?
  year      String?
  brand     String?
  target    Float    @default(0)
  market    Float    @default(0)
  status    String   @default("watching")
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
