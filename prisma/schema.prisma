generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String              @id @default(cuid())
  email      String              @unique
  username   String              @unique
  password   String
  pushToken  String?
  cards      Card[]
  wishes     Wish[]
  activities Activity[]
  snapshots  PortfolioSnapshot[]
  theme      String              @default("Purple")
  avatar     String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  friendshipsRequested Friendship[] @relation("FriendshipRequester")
  friendshipsReceived  Friendship[] @relation("FriendshipRecipient")
  tradesProposed       Trade[]      @relation("TradeProposer")
  tradesReceived       Trade[]      @relation("TradeReceiver")
}

model Card {
  id           String   @id @default(cuid())
  sport        String?
  year         String?
  player       String
  name         String?
  brand        String?
  num          String?
  cond         String?
  grade        String?
  qty          Int      @default(1)
  date         String?
  buy          Float    @default(0)
  val          Float    @default(0)
  notes        String?
  sold         Boolean  @default(false)
  soldPrice    Float?
  soldDate     String?
  purchaseDate String?
  rarity       String?
  edition      String?
  language     String?
  auto         Boolean  @default(false)
  gradingCo    String?
  autoGrade    String?
  imageUrl       String?
  traded         Boolean   @default(false)
  tradedTo       String?
  tradedFrom     String?
  tradedAt       DateTime?
  tradeId        String?
  originalUserId String?
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  player    String
  sport     String?
  detail    String?
  createdAt DateTime @default(now())
}

model PSACache {
  cert      String   @id
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortfolioSnapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  value     Float
  createdAt DateTime @default(now())
}

model Wish {
  id        String   @id @default(cuid())
  pri       String   @default("medium")
  sport     String?
  player    String
  name      String?
  year      String?
  brand     String?
  target    Float    @default(0)
  market    Float    @default(0)
  status    String   @default("watching")
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  recipientId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  recipient   User @relation("FriendshipRecipient", fields: [recipientId], references: [id])

  @@unique([requesterId, recipientId])
}

model Trade {
  id              String   @id @default(cuid())
  proposerId      String
  receiverId      String
  proposerCardIds String[]
  receiverCardIds String[]
  proposerCash    Float    @default(0)
  receiverCash    Float    @default(0)
  status          String   @default("pending")
  message         String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  proposer        User @relation("TradeProposer", fields: [proposerId], references: [id])
  receiver        User @relation("TradeReceiver", fields: [receiverId], references: [id])
}
